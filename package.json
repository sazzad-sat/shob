{
  "name": "shob",
  "private": true,
  "version": "0.0.2",
  "type": "module",
  "main": "electron-dist/main.js",
  "scripts": {
    "dev": "node scripts/dev-electron.mjs",
    "electron": "node scripts/dev-electron.mjs",
    "build": "pnpm run build:renderer && pnpm run build:electron:tsc",
    "build:electron": "pnpm run build && electron-builder",
    "lint": "eslint .",
    "preview": "vite preview",
    "prepare": "husky",
    "commit": "git-cz",
    "commit:retry": "git-cz --retry",
    "dev:electron:tsc": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "build:renderer": "tsc -b && vite build",
    "build:electron:tsc": "tsc -p tsconfig.electron.json"
  },
  "build": {
    "appId": "app.shob.desktop",
    "productName": "shob",
    "files": [
      "dist-renderer/**",
      "electron-dist/**",
      "electron/icons/**",
      "package.json"
    ],
    "directories": {
      "buildResources": "electron/icons",
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "electron/icons/icon.ico",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": "dmg",
      "icon": "electron/icons/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "electron/icons/icon.png"
    }
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-git"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron"
    ]
  },
  "dependencies": {
    "@kobalte/core": "^0.13.7",
    "@lydell/node-pty": "^1.2.0-beta.12",
    "@solidjs/router": "^0.15.3",
    "@xterm/addon-clipboard": "0.3.0-beta.213",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-image": "0.10.0-beta.213",
    "@xterm/addon-ligatures": "0.11.0-beta.213",
    "@xterm/addon-progress": "0.3.0-beta.213",
    "@xterm/addon-search": "0.17.0-beta.213",
    "@xterm/addon-serialize": "0.15.0-beta.213",
    "@xterm/addon-unicode11": "0.10.0-beta.213",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "0.20.0-beta.212",
    "@xterm/headless": "6.1.0-beta.213",
    "@xterm/xterm": "6.1.0-beta.213",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-solid": "^1.6.0",
    "solid-js": "^1.9.5",
    "solid-sonner": "^0.3.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.0",
    "commitizen": "^4.3.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "cz-git": "^1.12.0",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "git-cz": "^4.9.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "png-to-ico": "^3.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vite-plugin-solid": "^2.11.6",
    "wait-on": "^9.0.5"
  }
}
