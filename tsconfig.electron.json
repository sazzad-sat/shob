{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "electron-dist",
    "rootDir": "electron",
    "types": ["node", "electron"],
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "sourceMap": false,
    "strict": false,
    "skipLibCheck": true,
    "noEmitOnError": false
  },
  "include": ["electron/**/*.ts", "electron/**/*.cts"],
  "exclude": ["node_modules"]
}
